{
  "name": "discord-music-activity",
  "version": "1.0.0",
  "description": "Discord Rich Presenceに再生中の音楽を表示するアプリ",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "build": "node scripts/build.mjs",
    "package": "node scripts/build.mjs && pkg dist/bundle.cjs --targets node18-win-x64 --output dist/DiscordMusicActivity.exe"
  },
  "pkg": {
    "outputPath": "dist"
  },
  "keywords": [
    "discord",
    "rich-presence",
    "music",
    "now-playing"
  ],
  "license": "MIT",
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.17.0",
    "esbuild": "^0.28.0"
  },
  "overrides": {
    "into-stream": "^6.0.0"
  }
}
